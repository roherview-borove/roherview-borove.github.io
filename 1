<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>酷儿 - 产品失效分析科事件管理</title>
  <!-- 引入外部资源 -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
  <!-- Tailwind 配置 -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#8B5CF6',
            secondary: '#EC4899',
            accent: '#06B6D4',
            neutral: '#1F2937',
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
        },
      }
    }
  </script>
  <style type="text/tailwindcss">
    @layer utilities {
      .gradient-bg {
        background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 50%, #06B6D4 100%);
      }
      .gradient-text {
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        background-image: linear-gradient(to right, #8B5CF6, #EC4899, #06B6D4);
      }
      .timeline-line {
        background: linear-gradient(to bottom, #8B5CF6, #EC4899, #06B6D4);
      }
      .card-hover {
        transition: all 0.3s ease;
      }
      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      }
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- 头部标题区域 -->
  <header class="gradient-bg text-white py-8 px-4 shadow-lg">
    <div class="container mx-auto max-w-6xl">
      <h1 class="text-4xl md:text-5xl font-bold tracking-wide">酷儿</h1>
      <p class="mt-2 text-lg opacity-90">记录产品失效分析科的多彩时光</p>
    </div>
  </header>

  <!-- 操作栏区域 -->
  <section class="sticky top-0 bg-white shadow-sm z-40 py-4 px-4">
    <div class="container mx-auto max-w-6xl">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <!-- 筛选区域 -->
        <div class="flex flex-wrap gap-3">
          <input type="date" id="startDate" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none">
          <input type="date" id="endDate" class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none">
          <input type="text" id="searchKeyword" placeholder="关键词搜索..." class="px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none w-48">
          <button onclick="filterEvents()" class="bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-lg transition-all">
            <i class="fa fa-search mr-1"></i> 筛选
          </button>
        </div>
        <!-- 添加事件按钮 -->
        <button onclick="openAddModal()" class="bg-gradient-to-r from-primary to-secondary hover:opacity-90 text-white px-6 py-3 rounded-lg font-medium shadow-md transition-all">
          <i class="fa fa-plus-circle mr-2"></i> + 添加新事件
        </button>
      </div>
    </div>
  </section>

  <!-- 主体时间轴区域 -->
  <main class="container mx-auto max-w-6xl py-10 px-4">
    <div class="relative">
      <!-- 时间轴线 -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-1 timeline-line transform md:-translate-x-1/2"></div>
      
      <!-- 事件列表容器 -->
      <div id="timelineContainer" class="space-y-12 relative">
        <!-- 示例数据，JS会动态渲染这里 -->
      </div>
    </div>
  </main>

  <!-- 添加/编辑 事件弹窗 -->
  <div id="eventModal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl w-full max-w-3xl max-h-[90vh] overflow-y-auto shadow-2xl">
      <!-- 弹窗头部 -->
      <div class="gradient-bg text-white p-4 sticky top-0 flex justify-between items-center">
        <h2 class="text-xl font-semibold" id="modalTitle">添加新事件</h2>
        <div class="space-x-2">
          <button onclick="saveEvent()" class="bg-white text-primary px-4 py-1 rounded hover:bg-gray-100 transition-all">保存</button>
          <button onclick="closeModal()" class="bg-white text-gray-700 px-4 py-1 rounded hover:bg-gray-100 transition-all">取消</button>
        </div>
      </div>
      <!-- 表单内容 -->
      <form id="eventForm" class="p-6 space-y-5">
        <input type="hidden" id="eventId">
        <div>
          <label class="block text-gray-700 font-medium mb-2">时间</label>
          <input type="datetime-local" id="eventTime" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" required>
        </div>
        <div>
          <label class="block text-gray-700 font-medium mb-2">事件标题</label>
          <input type="text" id="eventTitle" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" required>
        </div>
        <div>
          <label class="block text-gray-700 font-medium mb-2">事件描述</label>
          <textarea id="eventDesc" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none resize-none" required></textarea>
        </div>
        <div>
          <label class="block text-gray-700 font-medium mb-2">事件图片（可多选）</label>
          <input type="file" id="eventImages" multiple accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary/10 file:text-primary hover:file:bg-primary/20 cursor-pointer">
          <div id="previewContainer" class="mt-3 flex flex-wrap gap-2"></div>
        </div>
      </form>
    </div>
  </div>

  <!-- 图片放大预览弹窗 -->
  <div id="imagePreviewModal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4">
    <div class="relative max-w-4xl max-h-[90vh]">
      <button onclick="closeImagePreview()" class="absolute -top-12 right-0 text-white text-3xl hover:text-red-500 transition-all"><i class="fa fa-times-circle"></i></button>
      <img id="previewImage" src="" class="max-w-full max-h-[90vh] object-contain">
    </div>
  </div>

  <script>
    // 初始化事件数据
    let events = JSON.parse(localStorage.getItem('queerEvents')) || [
      {
        id: 1,
        time: '2025-01-15T14:30',
        title: '产品外壳开裂问题分析',
        desc: '对生产线反馈的5起产品外壳开裂事件进行失效分析，确认是材料韧性不足导致，已提交优化方案。',
        images: ['https://picsum.photos/800/500?random=1']
      },
      {
        id: 2,
        time: '2025-01-10T09:15',
        title: '电路板短路故障排查',
        desc: '实验室检测发现3块电路板存在短路现象，通过金相分析定位到焊接缺陷，已调整焊接工艺参数。',
        images: ['https://picsum.photos/800/500?random=2', 'https://picsum.photos/800/500?random=3']
      }
    ];
    
    let currentEditId = null;
    let selectedFiles = [];
    let tempImages = [];

    // 页面加载渲染时间轴
    document.addEventListener('DOMContentLoaded', renderTimeline);

    // 渲染时间轴
    function renderTimeline(filteredEvents = null) {
      const container = document.getElementById('timelineContainer');
      container.innerHTML = '';
      
      const renderList = filteredEvents || [...events].sort((a, b) => new Date(b.time) - new Date(a.time));
      
      if (renderList.length === 0) {
        container.innerHTML = '<div class="text-center py-20 text-gray-500 text-lg"><i class="fa fa-inbox mr-2"></i>暂无事件记录</div>';
        return;
      }

      renderList.forEach(event => {
        const eventDate = new Date(event.time);
        const formatDate = eventDate.toLocaleString('zh-CN');
        
        const card = document.createElement('div');
        card.className = 'relative pl-12 md:pl-0 md:flex gap-6';
        card.innerHTML = `
          <div class="absolute left-4 md:left-1/2 w-5 h-5 bg-white border-4 border-primary rounded-full transform -translate-x-1/2 z-10"></div>
          <div class="md:w-1/3 md:pr-12 md:text-right mb-4 md:mb-0">
            <div class="text-primary font-semibold text-lg">${formatDate}</div>
            <h3 class="text-xl font-bold mt-2">${event.title}</h3>
            <p class="text-gray-600 mt-2 whitespace-pre-line">${event.desc}</p>
            <button onclick="editEvent(${event.id})" class="mt-3 text-accent hover:text-accent/80 transition-all">
              <i class="fa fa-edit mr-1"></i> 编辑
            </button>
          </div>
          <div class="md:w-2/3 md:pl-12">
            <div class="bg-white rounded-xl shadow-md p-4 card-hover">
              <div class="flex overflow-x-auto gap-3 scrollbar-hide pb-2">
                ${event.images.map((img, idx) => `
                  <img src="${img}" class="h-48 md:h-64 object-cover rounded cursor-pointer flex-shrink-0" onclick="showImagePreview('${img}')">
                `).join('')}
              </div>
            </div>
          </div>
        `;
        container.appendChild(card);
      });
    }

    // 打开新增弹窗
    function openAddModal() {
      currentEditId = null;
      document.getElementById('modalTitle').textContent = '添加新事件';
      document.getElementById('eventForm').reset();
      document.getElementById('previewContainer').innerHTML = '';
      selectedFiles = [];
      tempImages = [];
      document.getElementById('eventModal').style.display = 'flex';
    }

    // 编辑事件
    function editEvent(id) {
      currentEditId = id;
      const event = events.find(item => item.id === id);
      if (!event) return;
      
      document.getElementById('modalTitle').textContent = '编辑事件';
      document.getElementById('eventId').value = event.id;
      document.getElementById('eventTime').value = event.time;
      document.getElementById('eventTitle').value = event.title;
      document.getElementById('eventDesc').value = event.desc;
      tempImages = [...event.images];
      
      // 预览图片
      const previewContainer = document.getElementById('previewContainer');
      previewContainer.innerHTML = tempImages.map((img, idx) => `
        <div class="relative w-24 h-24">
          <img src="${img}" class="w-full h-full object-cover rounded">
          <button onclick="removeTempImage(${idx})" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs">×</button>
        </div>
      `).join('');
      
      selectedFiles = [];
      document.getElementById('eventModal').style.display = 'flex';
    }

    // 保存事件
    function saveEvent() {
      const time = document.getElementById('eventTime').value;
      const title = document.getElementById('eventTitle').value;
      const desc = document.getElementById('eventDesc').value;
      
      if (!time || !title || !desc) {
        alert('请填写必填字段');
        return;
      }

      // 处理图片
      const formData = new FormData();
      const images = [];
      
      // 临时图片（原有+新上传）
      const finalImages = [...tempImages];
      
      if (currentEditId) {
        // 编辑
        const index = events.findIndex(e => e.id === currentEditId);
        events[index] = {
          ...events[index],
          time, title, desc, images: finalImages
        };
      } else {
        // 新增
        const newEvent = {
          id: Date.now(),
          time,
          title,
          desc,
          images: finalImages
        };
        events.push(newEvent);
      }
      
      // 保存到本地存储
      localStorage.setItem('queerEvents', JSON.stringify(events));
      closeModal();
      renderTimeline();
    }

    // 关闭弹窗
    function closeModal() {
      document.getElementById('eventModal').style.display = 'none';
    }

    // 图片预览相关
    function showImagePreview(src) {
      document.getElementById('previewImage').src = src;
      document.getElementById('imagePreviewModal').style.display = 'flex';
    }
    
    function closeImagePreview() {
      document.getElementById('imagePreviewModal').style.display = 'none';
    }

    // 筛选事件
    function filterEvents() {
      const start = document.getElementById('startDate').value;
      const end = document.getElementById('endDate').value;
      const keyword = document.getElementById('searchKeyword').value.toLowerCase();
      
      let filtered = [...events];
      
      if (start) filtered = filtered.filter(e => new Date(e.time) >= new Date(start));
      if (end) filtered = filtered.filter(e => new Date(e.time) <= new Date(end + ' 23:59:59'));
      if (keyword) filtered = filtered.filter(e => e.title.toLowerCase().includes(keyword) || e.desc.toLowerCase().includes(keyword));
      
      filtered.sort((a, b) => new Date(b.time) - new Date(a.time));
      renderTimeline(filtered);
    }

    // 移除临时预览图片
    function removeTempImage(index) {
      tempImages.splice(index, 1);
      document.getElementById('previewContainer').innerHTML = tempImages.map((img, idx) => `
        <div class="relative w-24 h-24">
          <img src="${img}" class="w-full h-full object-cover rounded">
          <button onclick="removeTempImage(${idx})" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs">×</button>
        </div>
      `).join('');
    }

    // 监听图片上传预览
    document.getElementById('eventImages').addEventListener('change', function(e) {
      const files = Array.from(e.target.files);
      selectedFiles = files;
      
      files.forEach(file => {
        const reader = new FileReader();
        reader.onload = function(e) {
          tempImages.push(e.target.result);
          const previewContainer = document.getElementById('previewContainer');
          const imgHtml = `
            <div class="relative w-24 h-24">
              <img src="${e.target.result}" class="w-full h-full object-cover rounded">
              <button onclick="removeTempImage(${tempImages.length-1})" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs">×</button>
            </div>
          `;
          previewContainer.innerHTML += imgHtml;
        };
        reader.readAsDataURL(file);
      });
    });
  </script>
</body>
</html>
